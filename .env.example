# ============================================================
# GST Reconciliation Agent — Environment Variables Blueprint
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── App ────────────────────────────────────────────────────
APP_ENV=development                    # development | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database (Supabase / PostgreSQL + pgvector) ────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/database
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase project details
SUPABASE_URL=https://lqdflulybghsndfmkyno.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # From Settings > API

# ── Message Broker (RabbitMQ — CloudAMQP) ──────────────────
# Get from: https://www.cloudamqp.com/ → Create Instance → "Little Lemur" (free)
RABBITMQ_URL=amqps://user:password@hostname.cloudamqp.com/vhost

# ── LLM Providers ──────────────────────────────────────────
# Gemini (Google AI Studio — free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq (free tier): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# ── Google Cloud Platform ──────────────────────────────────
# For file storage (GCS) and Cloud Run deployment
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCS_BUCKET_NAME=gst-reconciliation-reports
# Path to your GCP service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ── GST Portal API ─────────────────────────────────────────
# Sandbox: https://sandbox.gst.gov.in/
# Production requires GSP registration
GST_PORTAL_BASE_URL=https://sandbox.gst.gov.in
GST_PORTAL_CLIENT_ID=your-gst-portal-client-id
GST_PORTAL_CLIENT_SECRET=your-gst-portal-client-secret

# ── Email (SendGrid) ───────────────────────────────────────
# Free tier: 100 emails/day. https://app.sendgrid.com/settings/api_keys
# Fallback: use SMTP (Gmail etc.) — see notification_service/README.md
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=no-reply@yourfirm.com
EMAIL_FROM_NAME=GST Reconciliation Agent

# SMTP fallback (use if SendGrid not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password        # Gmail App Password, not your Gmail password

# ── Observability (Grafana Cloud) ──────────────────────────
# Free tier: https://grafana.com/auth/sign-up/create-user
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-0.grafana.net/otlp
GRAFANA_INSTANCE_ID=your-grafana-instance-id
GRAFANA_API_KEY=your-grafana-api-key

# ── Service Ports (local dev) ──────────────────────────────
INGESTION_PORT=8001
ORCHESTRATION_PORT=8002
NOTIFICATION_PORT=8003
REPORT_PORT=8004
GATEWAY_PORT=8080

# ── Rate Limits ────────────────────────────────────────────
GEMINI_RPM_LIMIT=15          # Gemini free tier: 15 requests/minute
GROQ_RPD_LIMIT=14400         # Groq free tier: 14,400 requests/day
GST_PORTAL_RPH_LIMIT=100     # GST portal: 100 requests/hour per GSTIN

# ── Feature Flags ──────────────────────────────────────────
ENABLE_GCS_UPLOAD=false      # Set to true when GCP is configured
ENABLE_SENDGRID=false        # Set to true when SendGrid is configured
ENABLE_TRACING=false         # Set to true when Grafana is configured
MOCK_GST_PORTAL=true         # Use mock responses for GST portal (dev only)
